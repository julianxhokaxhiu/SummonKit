<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Wine requires the ability to map executable memory (JIT).
        Without this entitlement Wine will crash on Apple Silicon
        with hardened runtime enabled.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!--
        Allows Wine to use unsigned executable memory pages,
        needed for Wine's internal code generation.
    -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!--
        Disables library validation so Wine can load its own
        unsigned Winelib DLLs from Resources/wine/lib/wine/
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!--
        Required for Wine's DXVK/D3DMetal translation layer
        to access the GPU via Metal.
    -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Network client access (for downloading installer on first run) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Read/write access to user-selected files and app support folder -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- Allow access to ~/Library/Application Support -->
    <key>com.apple.security.temporary-exception.files.absolute-path.read-write</key>
    <array>
        <string>/Users/</string>
    </array>
</dict>
</plist>
